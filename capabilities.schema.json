{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Manifest",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "iri-reference"
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {},
      "additionalProperties": {
        "$ref": "#/$defs/Capability"
      }
    }
  },
  "required": [
    "version"
  ],
  "$defs": {
    "Capability": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "support": {
          "type": "boolean"
        }
      }
    }
  }
}
