{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Zarr Capability Manifest",
  "type": "object",
  "properties": {
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "RFC-3339 date"
    },
    "is_definition": {
      "type": "boolean"
    },
    "version": {
      "type": "integer"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Capability"
      }
    }
  },
  "required": [
    "version",
    "capabilities"
  ],
  "$defs": {
    "Capability": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "support": {
          "type": "boolean"
        }
      },
      "required": [
        "key"
      ]
    }
  }
}
